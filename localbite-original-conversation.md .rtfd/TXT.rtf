\cf23 const\cf10  remove = \cf19 [\cf22 34\cf19 ,\cf10  \cf22 44\cf19 ,\cf10  \cf22 66\cf19 ,\cf10  \cf22 72\cf19 ,\cf10  \cf22 74\cf19 ,\cf10  \cf22 75\cf19 ];\cf10 \
data\cf19 .\cf10 restaurants = data\cf19 .\cf10 restaurants\cf19 .\cf11 filter\cf19 ((\cf26 r\cf19 ,\cf26  i\cf19 )\cf10  => !remove\cf19 .\cf11 includes\cf19 (\cf10 i + \cf22 1\cf19 ));\cf10 \
fs\cf19 .\cf11 writeFileSync\cf19 (\cf21 'output.json'\cf19 ,\cf10  \cf12 JSON\cf19 .\cf11 stringify\cf19 (\cf10 data\cf19 ,\cf10  \cf23 null\cf19 ,\cf10  \cf22 2\cf19 ));\cf10 \cb1 \
